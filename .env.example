SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
OPENWEATHER_API_KEY=your-openweather-api-key
SLACK_CHANNEL_ID=C0XXXXXXXXX
NOTIFY_TIME=07:00
# DATABASE_URL이 있으면 PostgreSQL을 사용하고, 없으면 DB_PATH SQLite를 사용합니다.
# DATABASE_URL=postgresql://user:password@localhost:5432/slackbot
DB_PATH=./data/bot.db
CALENDAR_ACCESS_TOKEN=change-this-calendar-token
GOOGLE_TOKEN_DIR=./data/google_tokens
